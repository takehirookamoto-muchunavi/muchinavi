# MuchiNavi LINE Bot - 環境変数テンプレート
# 値を埋めて .env.local としてコピー → ローカル開発で使用
# 本番デプロイは `wrangler secret put` で Cloudflare 側に登録

# === LINE Messaging API ===
# LINE Developers Console → 既存公式アカウントのMessaging APIチャネル → 「Basic settings」
LINE_CHANNEL_SECRET=

# 同上 → 「Messaging API」タブ → Channel access token (long-lived) を発行
LINE_CHANNEL_ACCESS_TOKEN=

# === Anthropic Claude API ===
# https://console.anthropic.com/ → API keys → Create Key
ANTHROPIC_API_KEY=

# === Supabase ===
# https://supabase.com/dashboard → プロジェクト → Project Settings → API
SUPABASE_URL=
# 同上 → service_role key (★絶対に公開しない・Workers環境のみで使用)
SUPABASE_SERVICE_KEY=

# === Slack 介入通知 ===
# Slack App → Incoming Webhooks → Webhook URL
SLACK_WEBHOOK_URL=

# === 岡本さん個人LINE通知 ===
# LINE Messaging APIから岡本さん個人にPush送信するためのUser ID
# 岡本さん自身がBotを友だち追加 → 一度何か発言 → DBに保存されたuser_idをここに記入
LINE_PERSONAL_USER_ID=
